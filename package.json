{
  "name": "tfrp-helper-bot",
  "author": "The Flow RP Development Team",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Discord helper bot starter using discord.js, Prisma, MySQL, sticky messages, tickets, and global moderation.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "deploy:commands": "node src/deploy-commands.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test:db": "node test.js"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1",
    "mariadb": "^3.5.2",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
